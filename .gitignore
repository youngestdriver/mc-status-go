# Keep only source and docker-related files for newly added files.
# Everything else is ignored by default.
*

# Allow directories so nested include rules can match.
!*/

# Source code and Go module metadata
!**/*.go
!go.mod
!go.sum

# Docker packaging files
!Dockerfile
!.dockerignore
!docker-compose.yml
!docker-compose.yaml

# Repository control files
!.gitignore
